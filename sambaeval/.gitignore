# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
/build
next-env.d.ts

# production
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*

# typescript
*.tsbuildinfo

# python venv (created lazily by scripts/setup-venv.mjs)
/.venv/

# python bytecode cache (autogenerated when scripts/generators/* are imported)
__pycache__/
*.pyc

# sambaeval local data
# providers.json holds API keys and must never be committed.
/data/providers.json

# SciCode numeric reference data (~1 GB). Downloaded separately and pointed to
# via test_data_h5_path in scripts/generators/scicode_generator.py — never
# committed. See the SciCode section of the README.
*.h5

# SciCode raw upstream source, needed only to regenerate the fixture via
# convert_scicode.py. The committed, self-contained fixture
# (data/datasets/scicode/scicode_problems.jsonl) is the canonical artifact, so
# these inputs are not committed. The `problems_*.jsonl` glob covers the HF
# source files (problems_dev/test.jsonl) and the legacy problems_all.jsonl
# without matching the committed scicode_problems.jsonl. See the README in
# data/datasets/scicode/ for download links.
/data/datasets/scicode/problems_*.jsonl
/data/datasets/scicode/*.txt
